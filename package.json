{
  "name": "gesture-control-utility",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:ui": "vite build",
    "build:electron": "esbuild backend/electron/main.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/electron/main.cjs && esbuild backend/electron/preload.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/electron/preload.cjs",
    "build": "npm run build:ui && npm run build:electron",
    "electron:dev": "concurrently \"vite\" \"npm run build:electron && cross-env NODE_ENV=development electron .\"",
    "electron:start": "npm run build:electron && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.gesturecontrol.utility",
    "productName": "Gesture Control Utility",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/canvas/build/Release/*.node"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".venv",
        "to": ".venv",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-store": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
