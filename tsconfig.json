{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@components/*": ["./src/components/*"],
      "@views/*": ["./src/views/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@stores/*": ["./src/stores/*"],
      "@services/*": ["./src/services/*"],
      "@controllers": ["./src/controllers/index.ts"],
      "@controllers/*": ["./src/controllers/*"],
      "@ipc/*": ["./src/ipc/*"],
      "@utils/*": ["./src/utils/*"],
      "@animations/*": ["./src/animations/*"],
      "@assets/*": ["./src/assets/*"],
      "@backend/*": ["./backend/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src",
    "shared",
    "backend/electron/main.ts",
    "backend/electron/preload.ts",
    "backend/electron/engine_manager.ts",
    "backend/electron/WindowManager.ts"
  ]
}

